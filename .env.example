# Copy to .env and fill in your API keys.
# These are loaded into chrome.storage.local on first install via the popup settings.

# AI provider: claude | qwen | none
VITE_AI_PROVIDER=claude

# Anthropic Claude API key (https://console.anthropic.com/)
VITE_ANTHROPIC_API_KEY=

# Alibaba Qwen API key (https://dashscope.console.aliyun.com/)
VITE_QWEN_API_KEY=