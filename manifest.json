{
  "manifest_version": 3,
  "name": "HuntKit",
  "version": "1.0.0",
  "description": "AI-powered job hunting toolkit for LinkedIn, Naukri, and Indeed",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.naukri.com/*",
    "https://www.indeed.com/*",
    "https://in.indeed.com/*",
    "https://api.anthropic.com/*",
    "https://dashscope.aliyuncs.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://*.workday.com/*",
    "https://*.myworkday.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.wd1.myworkdayjobs.com/*",
    "https://*.wd2.myworkdayjobs.com/*",
    "https://*.wd3.myworkdayjobs.com/*",
    "https://*.wd4.myworkdayjobs.com/*",
    "https://*.wd5.myworkdayjobs.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.icims.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "HuntKit",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/in/*"
      ],
      "js": ["src/content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.naukri.com/*"],
      "js": ["src/content/naukri.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.indeed.com/*",
        "https://in.indeed.com/*"
      ],
      "js": ["src/content/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.workday.com/*",
        "https://*.myworkday.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*"
      ],
      "js": ["src/content/generic.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/sidebar/index.html", "src/sidebar/index.js", "client.js", "pdf.worker.min.js"],
      "matches": [
        "https://www.linkedin.com/*",
        "https://www.naukri.com/*",
        "https://www.indeed.com/*",
        "https://in.indeed.com/*"
      ]
    },
    {
      "resources": ["src/profile/index.html", "src/profile/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
